<UserControl x:Class="HRManagementSystem.Views.HR.Employee"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Employees Management" Grid.Row="0" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,16" Orientation="Horizontal">
            <Button x:Name="btnNew" Content="＋ New" Width="100" Height="36" Margin="0,0,8,0" Background="#F9D678" FontWeight="SemiBold" Click="btnNew_Click"/>
            <Button x:Name="btnDeactivate" Content="Deactive" Width="100" Height="36" Margin="0,0,8,0" Background="#EF4444" Foreground="White" Click="btnDeactivate_Click"/>
            <Button x:Name="btnActivate" Content="Active" Width="100" Height="36" Margin="0,0,16,0" Background="#22C55E" Foreground="White" Click="btnActivate_Click"/>
            <TextBox x:Name="txtSearchEmployees" Width="240" Height="36" Padding="8" Margin="0,0,8,0" VerticalContentAlignment="Center" TextChanged="txtSearchEmployees_TextChanged"/>
            <Button Content="Search" Width="90" Height="36" Background="#F9D678" FontWeight="SemiBold" Click="btnSearch_Click"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,16,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.15"/>
                </Border.Effect>

                <DataGrid x:Name="dgEmployees" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="34" HeadersVisibility="Column" GridLinesVisibility="None" SelectionMode="Single" SelectionChanged="dgEmployees_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding EmployeeId}" Width="90"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="2*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1*"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="1*"/>
                        <DataGridTextColumn Header="Department" Binding="{Binding Department.DepartmentName}" Width="1*"/>
                        <DataGridTextColumn Header="Position" Binding="{Binding Position.PositionName}" Width="1*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.15"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Employee Detail" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <TextBlock Text="Full Name"/>
                        <TextBox x:Name="txtFullName" Height="34" Padding="8" Margin="0,6,0,12"/>

                        <TextBlock Text="Email"/>
                        <TextBox x:Name="txtEmail" Height="34" Padding="8" Margin="0,6,0,12"/>

                        <TextBlock Text="Phone"/>
                        <TextBox x:Name="txtPhone" Height="34" Padding="8" Margin="0,6,0,12"/>

                        <TextBlock Text="Department"/>
                        <ComboBox x:Name="cbDepartment" Margin="0,6,0,12" DisplayMemberPath="DepartmentName" SelectedValuePath="DepartmentId"/>

                        <TextBlock Text="Position"/>
                        <ComboBox x:Name="cbPosition" Margin="0,6,0,12" DisplayMemberPath="PositionName" SelectedValuePath="PositionId"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Add" x:Name="btnAddEmployee" Width="100" Height="36" Margin="0,0,8,0" Background="#F9D678" FontWeight="SemiBold" Click="btnAddEmployee_Click"/>
                            <Button Content="Update" x:Name="btnUpdateEmployee" Width="100" Height="36" Background="#3B82F6" Foreground="White" Click="btnUpdateEmployee_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>