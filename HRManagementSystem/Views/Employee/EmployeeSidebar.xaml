<UserControl x:Class="HRManagementSystem.Views.Employee.EmployeeSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="240">
    <UserControl.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="14,6">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F9D678"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0F172A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="10">
            <Border Width="56"
                    Height="56"
                    Background="#F9D678"
                    CornerRadius="10"
                    Margin="0,0,0,12"
                    HorizontalAlignment="Center">
                <TextBlock Text="EM"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Employee Portal"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <Border Background="#1E293B"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,12,0,4"
                    Width="180">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="txtUserName"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>
                    <TextBlock x:Name="txtUserRole"
                               Foreground="#94A3B8"
                               FontSize="11"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="6,10">
            <Button x:Name="btnAttendance"
                    Content="My Attendance"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="btnAttendance_Click"/>
            <Button x:Name="btnLeaveRequest"
                    Content="My Leave Requests"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="btnLeaveRequest_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="10,15">
            <Separator Background="#1E293B" Height="1" Margin="0,8"/>
            <Button x:Name="btnLogout"
                    Content="Logout"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="btnLogout_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

