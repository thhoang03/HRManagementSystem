<Page x:Class="HRManagementSystem.Views.Employee.MyLeaveRequestsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Loaded="Page_Loaded"
      Background="#F8FAFC">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="My Leave Requests"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#0F172A"/>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.12"/>
                </Border.Effect>
                <DataGrid x:Name="dgMyLeaves"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeight="36"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding LeaveId}" Width="*"/>
                        <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate,StringFormat=d}" Width="*"/>
                        <DataGridTextColumn Header="End Date" Binding="{Binding EndDate,StringFormat=d}" Width="*"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding LeaveType}" Width="*"/>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.12"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Request Leave"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Start Date" FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpStartDate" Margin="0,6,0,12"/>

                    <TextBlock Text="End Date" FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpEndDate" Margin="0,6,0,12"/>

                    <TextBlock Text="Leave Type" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtLeaveType"
                             Height="36"
                             Padding="8"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Reason" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtReason"
                             Height="80"
                             Padding="8"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Margin="0,6,0,20"/>

                    <Button x:Name="btnSubmit"
                            Content="Submit Request"
                            Height="36"
                            Background="#22C55E"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="btnSubmit_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

