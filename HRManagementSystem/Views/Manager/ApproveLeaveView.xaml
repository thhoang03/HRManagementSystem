<Page x:Class="HRManagementSystem.Views.Manager.ApproveLeaveView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Loaded="Page_Loaded"
      Background="#F8FAFC">

        <Grid Margin="24">
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Leave Approval"
                           Grid.Row="0"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#0F172A"/>

                <StackPanel Grid.Row="1"
                            Margin="0,16,0,12"
                            Orientation="Horizontal">
                        <Button Content="Search"
                                Width="90"
                                Height="36"
                                Background="#F9D678"
                                BorderThickness="0"
                                Margin="0,0,8,0"
                                FontWeight="SemiBold"/>
                        <TextBox x:Name="txtSearch"
                                 Width="220"
                                 Height="36"
                                 Padding="8"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"
                                 TextChanged="txtSearch_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="0,0,0,16"
                            Orientation="Horizontal">
                        <ComboBox x:Name="cbStatus"
                                  Width="130"
                                  Height="36"
                                  Margin="0,0,8,0"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="cbStatus_SelectionChanged"/>
                        <ComboBox x:Name="cbLeaveType"
                                  Width="150"
                                  Height="36"
                                  Margin="0,0,8,0"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="cbLeaveType_SelectionChanged"/>
                        <TextBlock Text="From:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   Foreground="#334155"
                                   FontWeight="SemiBold"/>
                        <DatePicker x:Name="dpFromDate"
                                    Width="130"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    SelectedDateChanged="dpFromDate_SelectedDateChanged"/>
                        <TextBlock Text="To:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   Foreground="#334155"
                                   FontWeight="SemiBold"/>
                        <DatePicker x:Name="dpToDate"
                                    Width="130"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    SelectedDateChanged="dpToDate_SelectedDateChanged"/>
                        <Button Content="Clear"
                                Width="80"
                                Height="36"
                                Margin="0,0,8,0"
                                Background="#E2E8F0"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Click="btnClearFilter_Click"/>
                        <Button Content="Refresh"
                                Width="90"
                                Height="36"
                                Background="#F9D678"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Click="btnRefresh_Click"/>
                </StackPanel>

                <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,16,0">
                                <Border.Effect>
                                        <DropShadowEffect BlurRadius="12"
                                                          Opacity="0.12"/>
                                </Border.Effect>
                                <DataGrid x:Name="dgPendingLeaves"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          RowHeight="36"
                                          GridLinesVisibility="None"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          SelectionChanged="dgPendingLeaves_SelectionChanged">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Header="ID"
                                                                    Binding="{Binding LeaveId}"
                                                                    Width="*"/>
                                                <DataGridTextColumn Header="Employee"
                                                                    Binding="{Binding Employee.FullName}"
                                                                    Width="2*"/>
                                                <DataGridTextColumn Header="Start Date"
                                                                    Binding="{Binding StartDate,StringFormat=d}"
                                                                    Width="*"/>
                                                <DataGridTextColumn Header="End Date"
                                                                    Binding="{Binding EndDate,StringFormat=d}"
                                                                    Width="*"/>
                                                <DataGridTextColumn Header="Type"
                                                                    Binding="{Binding LeaveType}"
                                                                    Width="*"/>
                                                <DataGridTextColumn Header="Status"
                                                                    Binding="{Binding Status}"
                                                                    Width="*"/>
                                        </DataGrid.Columns>
                                </DataGrid>
                        </Border>

                        <Border Grid.Column="1"
                                Background="White"
                                CornerRadius="12"
                                Padding="20">
                                <Border.Effect>
                                        <DropShadowEffect BlurRadius="12"
                                                          Opacity="0.12"/>
                                </Border.Effect>

                                <StackPanel>
                                        <TextBlock Text="Request Detail"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,16"/>

                                        <TextBlock Text="Employee"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtEmployee"
                                                   Margin="0,6,0,12"
                                                   Foreground="#334155"/>

                                        <TextBlock Text="Date Range"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtDateRange"
                                                   Margin="0,6,0,12"
                                                   Foreground="#334155"/>

                                        <TextBlock Text="Leave Type"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtLeaveType"
                                                   Margin="0,6,0,12"
                                                   Foreground="#334155"/>

                                        <TextBlock Text="Reason"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtReason"
                                                   Margin="0,6,0,20"
                                                   TextWrapping="Wrap"
                                                   Foreground="#334155"/>

                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                                <Button x:Name="btnApprove"
                                                        Content="Approve"
                                                        Width="100"
                                                        Height="36"
                                                        Margin="0,0,8,0"
                                                        Background="#22C55E"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        FontWeight="SemiBold"
                                                        Click="btnApprove_Click"/>
                                                <Button x:Name="btnReject"
                                                        Content="Reject"
                                                        Width="100"
                                                        Height="36"
                                                        Background="#EF4444"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        FontWeight="SemiBold"
                                                        Click="btnReject_Click"/>
                                        </StackPanel>
                                </StackPanel>
                        </Border>
                </Grid>
        </Grid>
</Page>

