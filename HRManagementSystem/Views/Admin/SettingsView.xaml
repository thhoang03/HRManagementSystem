<Page x:Name="frmSettings"
      x:Class="HRManagementSystem.Views.Admin.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Loaded="frmSettings_Loaded"
      Background="#F8FAFC">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <TextBlock Text="Settings Management"
                   Grid.Row="0"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="#0F172A"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,16" Orientation="Horizontal">

            <Button x:Name="btnNew"
                    Content="+ New"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#F9D678"
                    FontWeight="SemiBold"
                    Click="btnNew_Click"/>

            <Button x:Name="btnActive"
                    Content="Active"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#22C55E"
                    Foreground="White"
                    Click="btnActive_Click"/>

            <Button x:Name="btnDeactive"
                    Content="Deactive"
                    Width="100"
                    Height="36"
                    Margin="0,0,16,0"
                    Background="#EF4444"
                    Foreground="White"
                    Click="btnDeactive_Click"/>

            <TextBox x:Name="txtSearch"
                     Width="220"
                     Height="36"
                     Padding="8"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     TextChanged="txtSearch_TextChanged"/>

            <Button Content="Search"
                    Width="90"
                    Height="36"
                    Background="#F9D678"
                    FontWeight="SemiBold"/>

        </StackPanel>

        <!-- CONTENT -->

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DATA GRID CARD -->

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,0">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.15"/>
                </Border.Effect>

                <DataGrid x:Name="dgSettings"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeight="34"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          SelectionChanged="dgSettings_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding SettingId}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Key"
                                            Binding="{Binding SettingKey}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Value"
                                            Binding="{Binding SettingValue}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="120"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

            <!-- DETAIL FORM -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="20">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.15"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="Setting Detail"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <!-- KEY -->

                    <TextBlock Text="Key"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="txtKey"
                             Height="36"
                             Padding="8"
                             Margin="0,6,0,12"/>

                    <!-- VALUE -->

                    <TextBlock Text="Value"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="txtValue"
                             Height="36"
                             Padding="8"
                             Margin="0,6,0,12"/>

                    <!-- DESCRIPTION -->

                    <TextBlock Text="Description"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="txtDescription"
                             Height="70"
                             Padding="8"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Margin="0,6,0,20"/>

                    <!-- BUTTONS -->

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button x:Name="btnAdd"
                                Content="Add"
                                Width="100"
                                Height="36"
                                Margin="0,0,8,0"
                                Background="#F9D678"
                                FontWeight="SemiBold"
                                Click="btnAdd_Click"/>

                        <Button x:Name="btnUpdate"
                                Content="Update"
                                Width="100"
                                Height="36"
                                Background="#3B82F6"
                                FontWeight="SemiBold"
                                Click="btnUpdate_Click"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Page>

