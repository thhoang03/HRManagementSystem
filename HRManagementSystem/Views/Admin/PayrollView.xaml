<Page x:Name="frmPayroll"
      x:Class="HRManagementSystem.Views.Admin.PayrollView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F8FAFC"
      Loaded="frmPayroll_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Payroll Management"
                   Grid.Row="0"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#0F172A"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,10" Orientation="Horizontal" VerticalAlignment="Center">

            <TextBlock Text="Month"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="#475569"/>

            <ComboBox x:Name="cbGenMonth"
                      Width="120"
                      Height="34"
                      Margin="0,0,16,0"/>

            <TextBlock Text="Year"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="#475569"/>

            <ComboBox x:Name="cbGenYear"
                      Width="120"
                      Height="34"
                      Margin="0,0,16,0"/>

            <Button Content="Generate"
                    x:Name="btnGenerate"
                    Width="110"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#F9D678"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="btnGenerate_Click"/>

            <Button Content="Save Payroll"
                    x:Name="btnSavePayroll"
                    Width="120"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#22C55E"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="btnSavePayroll_Click"/>

            <Button Content="Approve"
                    x:Name="btnApprove"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#3B82F6"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="btnApprove_Click"/>

            <Button Content="Pay"
                    x:Name="btnPay"
                    Width="90"
                    Height="36"
                    Margin="0,0,12,0"
                    Background="#0EA5E9"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="btnPay_Click"/>

            <TextBlock x:Name="txtMode"
                       VerticalAlignment="Center"
                       Foreground="#64748B"
                       FontStyle="Italic"/>

        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,16" Orientation="Horizontal">

            <TextBox x:Name="txtSearch"
                     Width="260"
                     Height="36"
                     Padding="8"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     BorderBrush="#CBD5E1"
                     BorderThickness="1"
                     TextChanged="txtSearch_TextChanged"/>

            <Button Content="Clear"
                    Height="36"
                    Padding="16,0"
                    Background="#E2E8F0"
                    BorderThickness="0"
                    Foreground="#0F172A"
                    Click="btnClearSearch_Click"/>

        </StackPanel>

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="16">

            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.12"/>
            </Border.Effect>

            <DataGrid x:Name="dgPayroll"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="36"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      BorderThickness="0">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding PayrollId}"
                                        Width="0.5*"/>

                    <DataGridTextColumn Header="Employee"
                                        Binding="{Binding EmployeeName}"
                                        Width="1.6*"/>

                    <DataGridTextColumn Header="Contract"
                                        Binding="{Binding ContractType}"
                                        Width="1*"/>

                    <DataGridTextColumn Header="Month"
                                        Binding="{Binding Month}"
                                        Width="0.6*"/>

                    <DataGridTextColumn Header="Year"
                                        Binding="{Binding Year}"
                                        Width="0.6*"/>

                    <DataGridTextColumn Header="Base"
                                        Binding="{Binding BaseSalary,StringFormat=N2}"
                                        Width="1*"/>

                    <DataGridTextColumn Header="Work"
                                        Binding="{Binding WorkDays}"
                                        Width="0.7*"/>

                    <DataGridTextColumn Header="Leave"
                                        Binding="{Binding LeaveDays}"
                                        Width="0.7*"/>

                    <DataGridTextColumn Header="Bonus"
                                        Binding="{Binding Bonus,StringFormat=N2}"
                                        Width="0.9*"/>

                    <DataGridTextColumn Header="Overtime"
                                        Binding="{Binding OvertimePay,StringFormat=N2}"
                                        Width="0.9*"/>

                    <DataGridTextColumn Header="Deduction"
                                        Binding="{Binding Deduction,StringFormat=N2}"
                                        Width="0.9*"/>

                    <DataGridTextColumn Header="Net"
                                        Binding="{Binding NetSalary,StringFormat=N2}"
                                        Width="1*"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="0.8*"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</Page>
