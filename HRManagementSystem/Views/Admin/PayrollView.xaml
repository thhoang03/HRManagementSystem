<Page x:Name="frmPayroll"
      x:Class="HRManagementSystem.Views.Admin.PayrollView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F8FAFC"
      Loaded="frmPayroll_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <TextBlock Text="Payroll Management"
                   Grid.Row="0"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#0F172A"/>

        <!-- ACTION BAR -->

        <StackPanel Grid.Row="1" Margin="0,16,0,10" Orientation="Horizontal">

            <Button Content="+ New"
                    x:Name="btnNew"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#F9D678"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="btnNew_Click"/>

            <Button Content="Delete"
                    x:Name="btnDelete"
                    Width="100"
                    Height="36"
                    Margin="0,0,16,0"
                    Background="#EF4444"
                    Foreground="White"
                    BorderThickness="0"
                    Click="btnDelete_Click"/>

            <TextBox x:Name="txtSearch"
                     Width="220"
                     Height="36"
                     Padding="8"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     BorderBrush="#CBD5E1"
                     BorderThickness="1"
                     TextChanged="txtSearch_TextChanged"/>

            <Button Content="Search"
                    Width="90"
                    Height="36"
                    Background="#F9D678"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>

        </StackPanel>

        <!-- FILTERS -->

        <Border Grid.Row="2"
                Background="White"
                Padding="12"
                CornerRadius="8"
                Margin="0,0,0,16">

            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Employee"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#475569"/>

                <ComboBox x:Name="cbFilterEmployees"
                          Width="220"
                          Height="34"
                          Margin="0,0,16,0"
                          SelectionChanged="cbFilterEmployees_SelectionChanged"/>

                <TextBlock Text="Month"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#475569"/>

                <ComboBox x:Name="cbFilterMonth"
                          Width="140"
                          Height="34"
                          Margin="0,0,16,0"
                          SelectionChanged="cbFilterMonth_SelectionChanged"/>

                <TextBlock Text="Year"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#475569"/>

                <ComboBox x:Name="cbFilterYear"
                          Width="110"
                          Height="34"
                          Margin="0,0,16,0"
                          SelectionChanged="cbFilterYear_SelectionChanged"/>

                <TextBlock Text="Status"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#475569"/>

                <ComboBox x:Name="cbFilterStatus"
                          Width="130"
                          Height="34"
                          Margin="0,0,16,0"
                          SelectionChanged="cbFilterStatus_SelectionChanged">
                    <ComboBoxItem Content="Pending"/>
                    <ComboBoxItem Content="Paid"/>
                    <ComboBoxItem Content="Canceled"/>
                </ComboBox>

                <Button Content="Clear"
                        Height="34"
                        Padding="14,0"
                        Background="#E2E8F0"
                        BorderThickness="0"
                        Foreground="#0F172A"
                        Click="btnClearFilter_Click"/>

            </StackPanel>

        </Border>

        <!-- CONTENT -->

        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- PAYROLL LIST -->

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,0">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.12"/>
                </Border.Effect>

                <DataGrid x:Name="dgPayroll"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeight="36"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          SelectionChanged="dgPayroll_SelectionChanged"
                          BorderThickness="0">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding PayrollId}"
                                            Width="0.5*"/>

                        <DataGridTextColumn Header="Employee"
                                            Binding="{Binding Employee.FullName}"
                                            Width="1.5*"/>

                        <DataGridTextColumn Header="Contract"
                                            Binding="{Binding Contract.ContractType}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Month"
                                            Binding="{Binding Month}"
                                            Width="0.5*"/>

                        <DataGridTextColumn Header="Year"
                                            Binding="{Binding Year}"
                                            Width="0.5*"/>

                        <DataGridTextColumn Header="Base"
                                            Binding="{Binding BaseSalary,StringFormat=N2}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Overtime"
                                            Binding="{Binding OvertimePay,StringFormat=N2}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Deduction"
                                            Binding="{Binding Deduction,StringFormat=N2}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Bonus"
                                            Binding="{Binding Bonus,StringFormat=N2}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Net"
                                            Binding="{Binding NetSalary,StringFormat=N2}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="0.8*"/>

                        <DataGridTextColumn Header="Created"
                                            Binding="{Binding CreatedAt,StringFormat=g}"
                                            Width="1.2*"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

            <!-- DETAIL FORM -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="20">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.12"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock Text="Payroll Detail"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Employee"/>
                        <ComboBox x:Name="cbEmployees"
                                  Margin="0,6,0,12"
                                  Height="34"
                                  SelectionChanged="cbEmployees_SelectionChanged"/>

                        <TextBlock Text="Contract"/>
                        <ComboBox x:Name="cbContracts"
                                  Margin="0,6,0,12"
                                  Height="34"/>

                        <TextBlock Text="Month"/>
                        <ComboBox x:Name="cbMonth"
                                  Margin="0,6,0,12"
                                  Height="34"/>

                        <TextBlock Text="Year"/>
                        <ComboBox x:Name="cbYear"
                                  Margin="0,6,0,12"
                                  Height="34"/>

                        <TextBlock Text="Base Salary"/>
                        <TextBox x:Name="txtBaseSalary"
                                 Height="34"
                                 Margin="0,6,0,12"
                                 Padding="8"
                                 BorderBrush="#CBD5E1"
                                 TextChanged="SalaryFields_TextChanged"/>

                        <TextBlock Text="Overtime Pay"/>
                        <TextBox x:Name="txtOvertimePay"
                                 Height="34"
                                 Margin="0,6,0,12"
                                 Padding="8"
                                 BorderBrush="#CBD5E1"
                                 TextChanged="SalaryFields_TextChanged"/>

                        <TextBlock Text="Deduction"/>
                        <TextBox x:Name="txtDeduction"
                                 Height="34"
                                 Margin="0,6,0,12"
                                 Padding="8"
                                 BorderBrush="#CBD5E1"
                                 TextChanged="SalaryFields_TextChanged"/>

                        <TextBlock Text="Bonus"/>
                        <TextBox x:Name="txtBonus"
                                 Height="34"
                                 Margin="0,6,0,12"
                                 Padding="8"
                                 BorderBrush="#CBD5E1"
                                 TextChanged="SalaryFields_TextChanged"/>

                        <TextBlock Text="Net Salary"/>
                        <TextBox x:Name="txtNetSalary"
                                 Height="34"
                                 Margin="0,6,0,12"
                                 Padding="8"
                                 BorderBrush="#CBD5E1"
                                 Background="#F1F5F9"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Status"/>
                        <ComboBox x:Name="cbStatus"
                                  Margin="0,6,0,12"
                                  Height="34">
                            <ComboBoxItem Content="Pending"/>
                            <ComboBoxItem Content="Paid"/>
                            <ComboBoxItem Content="Canceled"/>
                        </ComboBox>

                        <TextBlock Text="Created At"/>
                        <DatePicker x:Name="dpCreatedAt"
                                    Margin="0,6,0,20"
                                    Height="34"/>

                        <!-- ACTION BUTTONS -->

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">

                            <Button Content="Add"
                                    x:Name="btnAdd"
                                    Width="100"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Background="#22C55E"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Click="btnAdd_Click"/>

                            <Button Content="Update"
                                    x:Name="btnUpdate"
                                    Width="100"
                                    Height="36"
                                    Background="#F9D678"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Click="btnUpdate_Click"/>

                        </StackPanel>

                    </StackPanel>

                </ScrollViewer>

            </Border>

        </Grid>

    </Grid>

</Page>
