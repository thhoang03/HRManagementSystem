<Page x:Name="frmEmployees"
      x:Class="HRManagementSystem.Views.Admin.EmployeesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F8FAFC"
      Loaded="frmEmployees_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <TextBlock Text="Employees Management"
                   Grid.Row="0"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="#0F172A"/>

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,16"
                    Orientation="Horizontal">

            <TextBox x:Name="txtSearch"
                     Width="220"
                     Height="36"
                     Padding="8"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     TextChanged="txtSearch_TextChanged"/>

            <Button Content="Search"
                    Width="90"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#F9D678"
                    FontWeight="SemiBold"/>

            <Button Content="Deactive"
                    x:Name="btnDelete"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#EF4444"
                    Foreground="White"
                    Click="btnDelete_Click"/>

            <Button Content="Active"
                    x:Name="btnActive"
                    Width="100"
                    Height="36"
                    Margin="0,0,16,0"
                    Background="#22C55E"
                    Foreground="White"
                    Click="btnActive_Click"/>

        </StackPanel>


        <StackPanel Grid.Row="2"
                    Margin="0,0,0,16"
                    Orientation="Horizontal">
            <TextBlock Text="Department:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       Foreground="#334155"
                       FontWeight="SemiBold"/>
            <ComboBox x:Name="cbFilterDepartment"
                      Width="150"
                      Height="36"
                      Margin="0,0,8,0"
                      VerticalContentAlignment="Center"
                      SelectionChanged="cbFilterDepartment_SelectionChanged"/>

            <TextBlock Text="Position:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       Foreground="#334155"
                       FontWeight="SemiBold"/>
            <ComboBox x:Name="cbFilterPosition"
                      Width="150"
                      Height="36"
                      Margin="0,0,8,0"
                      VerticalContentAlignment="Center"
                      SelectionChanged="cbFilterPosition_SelectionChanged"/>

            <TextBlock Text="Status:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       Foreground="#334155"
                       FontWeight="SemiBold"/>
            <ComboBox x:Name="cbFilterStatus"
                      Width="120"
                      Height="36"
                      Margin="0,0,8,0"
                      VerticalContentAlignment="Center"
                      SelectionChanged="cbFilterStatus_SelectionChanged">
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Deactive"/>
                <ComboBoxItem Content="Inactive"/>
            </ComboBox>

            <TextBlock Text="Gender:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       Foreground="#334155"
                       FontWeight="SemiBold"/>
            <ComboBox x:Name="cbFilterGender"
                      Width="110"
                      Height="36"
                      Margin="0,0,8,0"
                      VerticalContentAlignment="Center"
                      SelectionChanged="cbFilterGender_SelectionChanged">
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Male"/>
                <ComboBoxItem Content="Female"/>
            </ComboBox>

            <Button Content="Clear"
                    Width="80"
                    Height="36"
                    Margin="8,0,0,0"
                    Background="#E2E8F0"
                    FontWeight="SemiBold"
                    Click="btnClearFilter_Click"/>
        </StackPanel>

        <!-- CONTENT -->

        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <!-- EMPLOYEE LIST -->

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,0">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12"
                                      Opacity="0.15"/>
                </Border.Effect>

                <DataGrid x:Name="dgEmployees"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeight="34"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding EmployeeId}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Full Name"
                                            Binding="{Binding FullName}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Gender"
                                            Binding="{Binding Gender}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="DOB"
                                            Binding="{Binding DoB}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Phone"
                                            Binding="{Binding Phone}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Department"
                                            Binding="{Binding Department.DepartmentName}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Position"
                                            Binding="{Binding Position.PositionName}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

        </Grid>

    </Grid>

</Page>
