<Page x:Name="frmEmployees" x:Class="HRManagementSystem.Views.Admin.EmployeesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F8FAFC" Loaded="frmEmployees_Loaded">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <TextBlock Text="Employees Management"
                   Grid.Row="0"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="#0F172A"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,16" Orientation="Horizontal">

            <Button Content="+ New"
                    x:Name="btnNew"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#F9D678"
                    FontWeight="SemiBold" Click="btnNew_Click"/>

            <Button Content="Delete"
                    x:Name="btnDelete"
                    Width="100"
                    Height="36"
                    Margin="0,0,16,0"
                    Background="#EF4444"
                    Foreground="White" Click="btnDelete_Click"/>

            <TextBox x:Name="txtSearch"
                     Width="220"
                     Height="36"
                     Padding="8"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center" TextChanged="txtSearch_TextChanged"/>

            <Button Content="Search"
                    Width="90"
                    Height="36"
                    Background="#F9D678"
                    FontWeight="SemiBold"/>

        </StackPanel>

        <!-- CONTENT -->

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>


            <!-- EMPLOYEE LIST -->

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,0">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.15"/>
                </Border.Effect>

                <DataGrid x:Name="dgEmployees"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeight="34"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column" SelectionChanged="dgEmployees_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding EmployeeID}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Full Name"
                                            Binding="{Binding FullName}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Gender"
                                            Binding="{Binding Gender}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="DOB"
                                            Binding="{Binding DoB}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Phone"
                                            Binding="{Binding Phone}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Department"
                                            Binding="{Binding Department.DepartmentName}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Position"
                                            Binding="{Binding Position.PositionName}"
                                            Width="1*"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>


            <!-- EMPLOYEE DETAIL -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="20">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.15"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock Text="Employee Detail"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <!-- FULL NAME -->

                        <TextBlock Text="Full Name"/>
                        <TextBox x:Name="txtName"
                                 Height="34"
                                 Margin="0,6,0,12"
                                 Padding="8"/>

                        <!-- GENDER -->

                        <TextBlock Text="Gender"/>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <RadioButton Content="Male"
                                         x:Name="rbMale"
                                         IsChecked="true"
                                         GroupName="gender"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="Female"
                                         x:Name="rbFemale"
                                         GroupName="gender"/>
                        </StackPanel>

                        <!-- DATE OF BIRTH -->

                        <TextBlock Text="Date of Birth"/>
                        <DatePicker x:Name="dpDOB"
                                    Margin="0,6,0,12"/>

                        <!-- EMAIL -->

                        <TextBlock Text="Email"/>
                        <TextBox x:Name="txtEmail"
                                 Height="34"
                                 Margin="0,6,0,12"
                                 Padding="8"/>

                        <!-- PHONE -->

                        <TextBlock Text="Phone"/>
                        <TextBox x:Name="txtPhone"
                                 Height="34"
                                 Margin="0,6,0,12"
                                 Padding="8"/>

                        <!-- ADDRESS -->

                        <TextBlock Text="Address"/>
                        <TextBox x:Name="txtAddress"
                                 Height="34"
                                 Margin="0,6,0,12"
                                 Padding="8"/>

                        <!-- HIRE DATE -->

                        <TextBlock Text="Hire Date"/>
                        <DatePicker x:Name="dpHireDate"
                                    Margin="0,6,0,12"/>

                        <!-- DEPARTMENT -->

                        <TextBlock Text="Department"/>
                        <ComboBox x:Name="cbDepartments"
                                  Margin="0,6,0,12"/>

                        <!-- POSITION -->

                        <TextBlock Text="Position"/>
                        <ComboBox x:Name="cbPositions"
                                  Margin="0,6,0,12"/>

                        <!-- STATUS -->

                        <TextBlock Text="Status"/>
                        <ComboBox x:Name="cbStatus"
                                  Margin="0,6,0,20">

                            <ComboBoxItem Content="Active"/>
                            <ComboBoxItem Content="Inactive"/>

                        </ComboBox>

                        <!-- ACTION BUTTONS -->

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">

                            <Button Content="Add"
                                    x:Name="btnAdd"
                                    Width="100"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Background="#F9D678"
                                    FontWeight="SemiBold" Click="btnAdd_Click"/>

                            <Button Content="Update"
                                    x:Name="btnUpdate"
                                    Width="100"
                                    Height="36"
                                    Background="#3B82F6"
                                    Foreground="White"
                                    FontWeight="SemiBold" Click="btnUpdate_Click"/>

                        </StackPanel>

                    </StackPanel>

                </ScrollViewer>

            </Border>

        </Grid>

    </Grid>

</Page>