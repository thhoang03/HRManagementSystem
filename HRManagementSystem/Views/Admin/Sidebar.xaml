<UserControl x:Class="HRManagementSystem.Views.Admin.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="240">

        <UserControl.Resources>

                <!-- Sidebar Button Style -->
                <Style x:Key="SidebarButtonStyle"
                       TargetType="Button">

                        <Setter Property="Height"
                                Value="44"/>
                        <Setter Property="Margin"
                                Value="10,4"/>
                        <Setter Property="Foreground"
                                Value="#E5E7EB"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="FontSize"
                                Value="14"/>
                        <Setter Property="HorizontalContentAlignment"
                                Value="Left"/>

                        <Setter Property="Template">
                                <Setter.Value>

                                        <ControlTemplate TargetType="Button">

                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="8"
                                                        Padding="14,6">

                                                        <ContentPresenter VerticalAlignment="Center"/>

                                                </Border>

                                                <ControlTemplate.Triggers>

                                                        <!-- Hover -->
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="border"
                                                                        Property="Background"
                                                                        Value="#1E293B"/>
                                                        </Trigger>

                                                        <!-- Click -->
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter TargetName="border"
                                                                        Property="Background"
                                                                        Value="#F9D678"/>
                                                                <Setter Property="Foreground"
                                                                        Value="#0F172A"/>
                                                        </Trigger>

                                                </ControlTemplate.Triggers>

                                        </ControlTemplate>

                                </Setter.Value>
                        </Setter>

                </Style>

        </UserControl.Resources>


        <!-- SIDEBAR -->
        <Grid Background="#0F172A">

                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <!-- LOGO + USER INFO -->
                <StackPanel Margin="10">

                        <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- LOGO -->
                                <Border Width="56"
                                        Height="56"
                                        Background="#F9D678"
                                        CornerRadius="10"
                                        Margin="0,0,0,12"
                                        HorizontalAlignment="Center">

                                        <TextBlock Text="HR"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#0F172A"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                </Border>

                        </Grid>

                        <TextBlock x:Name="txtAppName"
                                   Text="HR Management"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="txtAppSubName"
                                   Text="System"
                                   FontSize="12"
                                   Foreground="#94A3B8"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>


                        <!-- USER INFO -->

                        <Border x:Name="bdUserInfo"
                                Background="#1E293B"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,8,0,4"
                                Width="180">

                                <StackPanel HorizontalAlignment="Center">
                                        <!-- Username -->
                                        <TextBlock x:Name="txtUserName"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"/>

                                        <!-- Role -->
                                        <TextBlock x:Name="txtUserRole"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"
                                                   TextAlignment="Center"/>

                                </StackPanel>

                        </Border>

                </StackPanel>

                <!-- MENU -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Margin="6,10">

                        <Grid>

                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0"
                                        x:Name="btnDashboard"
                                        Content="Dashboard"
                                        Tag="Dashboard"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Click="btnDashboard_Click"/>

                                <Button Grid.Row="1"
                                        x:Name="btnUser"
                                        Content="User"
                                        Tag="User"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Click="btnUser_Click"/>

                                <Button Grid.Row="2"
                                        x:Name="btnDepartments"
                                        Content="Departments"
                                        Tag="Departments"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Click="btnDepartments_Click"/>

                                <Button Grid.Row="3"
                                        x:Name="btnPositions"
                                        Content="Positions"
                                        Tag="Positions"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Click="btnPositions_Click"/>

                                <Button Grid.Row="4"
                                        x:Name="btnEmployees"
                                        Content="Employees"
                                        Tag="Employees"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Click="btnEmployees_Click"/>

                                <Button Grid.Row="5"
                                        x:Name="btnContracts"
                                        Content="Contracts"
                                        Tag="Contracts"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Click="btnContracts_Click"/>

                                <Button Grid.Row="6"
                                        x:Name="btnAttendance"
                                        Content="Attendance"
                                        Tag="Attendance"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Click="btnAttendance_Click"/>

                                <Button Grid.Row="7"
                                        x:Name="btnPayroll"
                                        Content="Payroll"
                                        Tag="Payroll"
                                        Style="{StaticResource SidebarButtonStyle}"
                                                Click="btnPayroll_Click"/>

                                <Button Grid.Row="8"
                                        x:Name="btnLeaveRequests"
                                        Content="Leave Requests"
                                        Tag="LeaveRequests"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Click="btnLeaveRequests_Click"/>

                                <Button Grid.Row="9"
                                        x:Name="btnSettings"
                                        Content="Settings"
                                        Tag="Settings"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Click="btnSettings_Click"/>

                                <Button Grid.Row="10"
                                        x:Name="btnReports"
                                        Content="Reports"
                                        Tag="Reports"
                                        Style="{StaticResource SidebarButtonStyle}"/>

                        </Grid>

                </ScrollViewer>

                <!-- FOOTER -->
                <StackPanel Grid.Row="2"
                            Margin="10,15">

                        <!-- TOGGLER -->
                        <Button x:Name="btnToggle"
                                Width="32"
                                Height="32"
                                Margin="0,10,10,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="#1E293B"
                                Foreground="#E5E7EB"
                                BorderThickness="0"
                                Click="btnToggle_Click"/>

                        <Separator Background="#1E293B"
                                   Height="1"
                                   Margin="0,8"/>

                        <Button x:Name="btnLogout"
                                Content="Logout"
                                Tag="Logout"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="btnLogout_Click"/>

                </StackPanel>


        </Grid>

</UserControl>
