<UserControl x:Class="HRManagementSystem.Views.Admin.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">

            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="14,6">

                            <ContentPresenter VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#1E293B"/>
                            </Trigger>

                            <!-- Click -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#F9D678"/>
                                <Setter Property="Foreground"
                                        Value="#0F172A"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

    </UserControl.Resources>


    <!-- SIDEBAR -->
    <Grid Background="#0F172A">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- LOGO -->
        <StackPanel Margin="20,25"
                    HorizontalAlignment="Center">

            <Border Width="56"
                    Height="56"
                    Background="#F9D678"
                    CornerRadius="10"
                    Margin="0,0,0,12">

                <TextBlock Text="HR"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

            </Border>

            <TextBlock Text="HR Management"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="System"
                       FontSize="12"
                       Foreground="#94A3B8"
                       HorizontalAlignment="Center"/>

        </StackPanel>


        <!-- MENU -->
        <StackPanel Grid.Row="1"
                    Margin="8,10">

            <Button x:Name="btnDashboard"
                    Content="Dashboard"
                    Style="{StaticResource SidebarButtonStyle}"/>

            <Button x:Name="btnDepartments"
                    Content="Departments"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="btnDepartments_Click"/>

            <Button x:Name="btnPositions"
                    Content="Positions"
                    Style="{StaticResource SidebarButtonStyle}" Click="btnPositions_Click"/>

            <Button x:Name="btnEmployees"
                    Content="Employees"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="btnEmployees_Click"/>

            <Button x:Name="btnContracts"
                    Content="Contracts"
                    Style="{StaticResource SidebarButtonStyle}" Click="btnContracts_Click"/>

            <Button x:Name="btnAttendance"
                    Content="Attendance"
                    Style="{StaticResource SidebarButtonStyle}"/>

            <Button x:Name="btnPayroll"
                    Content="Payroll"
                    Style="{StaticResource SidebarButtonStyle}"/>

            <Button x:Name="btnReports"
                    Content="Reports"
                    Style="{StaticResource SidebarButtonStyle}"/>

        </StackPanel>


        <!-- FOOTER -->
        <StackPanel Grid.Row="2"
                    Margin="10,15">

            <Separator Background="#1E293B"
                       Height="1"
                       Margin="0,8"/>

            <Button Content="Logout"
                    Style="{StaticResource SidebarButtonStyle}"/>

        </StackPanel>


    </Grid>

</UserControl>