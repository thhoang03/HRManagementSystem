<Page x:Name="frmAttendance"
      x:Class="HRManagementSystem.Views.Admin.AttendanceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Loaded="frmAttendance_Loaded"
      Background="#F8FAFC">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Attendance Management"
                   Grid.Row="0"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#0F172A"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,10" Orientation="Horizontal">

            <TextBox x:Name="txtSearch"
                     Width="220"
                     Height="36"
                     Padding="8"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     BorderBrush="#CBD5E1"
                     BorderThickness="1"
                     TextChanged="txtSearch_TextChanged"/>

            <Button Content="Search"
                    Width="90"
                    Height="36"
                    Background="#F9D678"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>

        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                Padding="12"
                CornerRadius="8"
                Margin="0,0,0,16">

            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Employee"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#475569"/>

                <ComboBox x:Name="cbFilterEmployees"
                          Width="220"
                          Height="34"
                          Margin="0,0,16,0"
                          SelectionChanged="cbFilterEmployees_SelectionChanged"/>

                <TextBlock Text="Date"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#475569"/>

                <DatePicker x:Name="dpFilterDate"
                            Width="150"
                            Height="34"
                            Margin="0,0,16,0"
                            SelectedDateChanged="dpFilterDate_SelectedDateChanged"/>

                <TextBlock Text="Month"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#475569"/>

                <ComboBox x:Name="cbFilterMonth"
                          Width="140"
                          Height="34"
                          Margin="0,0,16,0"
                          SelectionChanged="cbFilterMonth_SelectionChanged"/>

                <TextBlock Text="Year"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#475569"/>

                <ComboBox x:Name="cbFilterYear"
                          Width="110"
                          Height="34"
                          Margin="0,0,16,0"
                          SelectionChanged="cbFilterYear_SelectionChanged"/>

                <Button Content="Clear"
                        Height="34"
                        Padding="14,0"
                        Background="#E2E8F0"
                        BorderThickness="0"
                        Foreground="#0F172A"
                        Click="btnClearFilter_Click"/>

            </StackPanel>

        </Border>

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="16">

            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.12"/>
            </Border.Effect>

            <DataGrid x:Name="dgAttendance"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="36"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      BorderThickness="0">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding AttendanceId}"
                                        Width="0.5*"/>

                    <DataGridTextColumn Header="Employee"
                                        Binding="{Binding Employee.FullName}"
                                        Width="1.5*"/>

                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding AttendanceDate}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Check In"
                                        Binding="{Binding CheckIn,StringFormat=g}"
                                        Width="1*"/>

                    <DataGridTextColumn Header="Check Out"
                                        Binding="{Binding CheckOut,StringFormat=g}"
                                        Width="1*"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="0.5*"/>

                    <DataGridTextColumn Header="Device IP"
                                        Binding="{Binding DeviceIp}"
                                        Width="1*"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</Page>
