<Page x:Name="frmDashboard"
      x:Class="HRManagementSystem.Views.Admin.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Loaded="frmDashboard_Loaded"
      Background="#F8FAFC">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <TextBlock Text="Dashboard"
                   Grid.Row="0"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="#0F172A"/>

        <!-- STATS -->

        <WrapPanel Grid.Row="1" Margin="0,16,0,16" ItemHeight="100" ItemWidth="220">

            <Border Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Employees" Foreground="#64748B"/>
                    <TextBlock x:Name="txtEmployeesCount" Text="0" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Departments" Foreground="#64748B"/>
                    <TextBlock x:Name="txtDepartmentsCount" Text="0" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Positions" Foreground="#64748B"/>
                    <TextBlock x:Name="txtPositionsCount" Text="0" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Users" Foreground="#64748B"/>
                    <TextBlock x:Name="txtUsersCount" Text="0" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Active Contracts" Foreground="#64748B"/>
                    <TextBlock x:Name="txtActiveContractsCount" Text="0" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Contracts" Foreground="#64748B"/>
                    <TextBlock x:Name="txtContractsCount" Text="0" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </WrapPanel>

        <!-- CONTENT -->

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- RECENT EMPLOYEES -->

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,16,0">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.15"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="Recent Employees"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <DataGrid x:Name="dgRecentEmployees"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              RowHeight="32"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding EmployeeId}" Width="80"/>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="2*"/>
                            <DataGridTextColumn Header="Department" Binding="{Binding Department.DepartmentName}" Width="2*"/>
                            <DataGridTextColumn Header="Hire Date" Binding="{Binding HireDate}" Width="*"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </Border>

            <!-- RECENT LOGINS -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="16">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.15"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="Recent Logins"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <DataGrid x:Name="dgRecentLogins"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              RowHeight="32"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="*"/>
                            <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin, StringFormat=g}" Width="*"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Page>
