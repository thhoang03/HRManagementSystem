<Page x:Class="HRManagementSystem.Views.Admin.Reports.PayrollReportView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Loaded="Page_Loaded"
      Background="#F8FAFC">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Payroll Report" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Salary summary by month, department and employee" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- FILTER BAR -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.08"/>
            </Border.Effect>
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbMonth" Width="130" Height="34" Margin="0,0,12,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="Year:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbYear" Width="90" Height="34" Margin="0,0,16,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="Department:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbDepartment" Width="160" Height="34" Margin="0,0,16,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbStatus" Width="110" Height="34" Margin="0,0,16,0" VerticalContentAlignment="Center"/>

                <Button x:Name="btnFilter" Content="🔍  Filter" Width="100" Height="34"
                        Background="#0F172A" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="btnFilter_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </WrapPanel>
        </Border>

        <!-- SUMMARY CARDS -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,16" ItemHeight="80" ItemWidth="200">
            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Base Salary" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="txtTotalBase" Text="0" FontSize="18" FontWeight="Bold" Foreground="#3B82F6"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Net Salary" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="txtTotalNet" Text="0" FontSize="18" FontWeight="Bold" Foreground="#10B981"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Bonus" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="txtTotalBonus" Text="0" FontSize="18" FontWeight="Bold" Foreground="#8B5CF6"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Deduction" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="txtTotalDeduction" Text="0" FontSize="18" FontWeight="Bold" Foreground="#EF4444"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- DATA GRID -->
        <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.08"/>
            </Border.Effect>
            <DataGrid x:Name="dgReport" AutoGenerateColumns="False" IsReadOnly="True"
                      RowHeight="36" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9" HeadersVisibility="Column"
                      BorderThickness="0" AlternatingRowBackground="#F8FAFC">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#374151"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Employee"    Binding="{Binding FullName}"                      Width="2*"/>
                    <DataGridTextColumn Header="Department"  Binding="{Binding Department}"                    Width="1.5*"/>
                    <DataGridTextColumn Header="Month/Year"  Binding="{Binding MonthYear}"                     Width="*"/>
                    <DataGridTextColumn Header="Base Salary" Binding="{Binding BaseSalary, StringFormat=N0}"   Width="*"/>
                    <DataGridTextColumn Header="Overtime"    Binding="{Binding OvertimePay, StringFormat=N0}"  Width="*"/>
                    <DataGridTextColumn Header="Bonus"       Binding="{Binding Bonus, StringFormat=N0}"        Width="*"/>
                    <DataGridTextColumn Header="Deduction"   Binding="{Binding Deduction, StringFormat=N0}"    Width="*"/>
                    <DataGridTextColumn Header="Net Salary"  Binding="{Binding NetSalary, StringFormat=N0}"    Width="*"/>
                    <DataGridTextColumn Header="Status"      Binding="{Binding Status}"                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="4" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="txtRowCount" Text="" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#64748B" FontSize="13"/>
                <Button x:Name="btnExportCsv" Content="📥  Export CSV" Width="130" Height="36"
                        Background="#0F172A" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="btnExportCsv_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
