<Page x:Class="HRManagementSystem.Views.Admin.Reports.ContractReportView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Loaded="Page_Loaded"
      Background="#F8FAFC">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Contract Report" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Contract status overview and expiry tracking" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- FILTER BAR -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.08"/>
            </Border.Effect>
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbStatus" Width="130" Height="34" Margin="0,0,16,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="Contract Type:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbContractType" Width="150" Height="34" Margin="0,0,16,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="Department:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbDepartment" Width="160" Height="34" Margin="0,0,16,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="Expiring within (days):" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbExpiry" Width="100" Height="34" Margin="0,0,16,0" VerticalContentAlignment="Center"/>

                <Button x:Name="btnFilter" Content="🔍  Filter" Width="100" Height="34"
                        Background="#0F172A" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="btnFilter_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </WrapPanel>
        </Border>

        <!-- SUMMARY CARDS -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,16" ItemHeight="80" ItemWidth="185">
            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Contracts" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="txtTotal" Text="0" FontSize="22" FontWeight="Bold" Foreground="#3B82F6"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Active" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="txtActive" Text="0" FontSize="22" FontWeight="Bold" Foreground="#10B981"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Expired" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="txtExpired" Text="0" FontSize="22" FontWeight="Bold" Foreground="#EF4444"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Expiring Soon" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="txtExpiringSoon" Text="0" FontSize="22" FontWeight="Bold" Foreground="#F59E0B"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Salary/Month" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="txtTotalSalary" Text="0" FontSize="18" FontWeight="Bold" Foreground="#8B5CF6"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- DATA GRID -->
        <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.08"/>
            </Border.Effect>
            <DataGrid x:Name="dgReport" AutoGenerateColumns="False" IsReadOnly="True"
                      RowHeight="36" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9" HeadersVisibility="Column"
                      BorderThickness="0" AlternatingRowBackground="#F8FAFC">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#374151"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Employee"       Binding="{Binding FullName}"                           Width="2*"/>
                    <DataGridTextColumn Header="Department"     Binding="{Binding Department}"                         Width="1.5*"/>
                    <DataGridTextColumn Header="Contract Type"  Binding="{Binding ContractType}"                       Width="*"/>
                    <DataGridTextColumn Header="Start Date"     Binding="{Binding StartDate, StringFormat=dd/MM/yyyy}" Width="*"/>
                    <DataGridTextColumn Header="End Date"       Binding="{Binding EndDate}"                            Width="*"/>
                    <DataGridTextColumn Header="Salary"         Binding="{Binding Salary, StringFormat=N0}"            Width="*"/>
                    <DataGridTextColumn Header="Status"         Binding="{Binding Status}"                             Width="*"/>
                    <DataGridTextColumn Header="Days Remaining" Binding="{Binding DaysRemaining}"                      Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="4" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="txtRowCount" Text="" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#64748B" FontSize="13"/>
                <Button x:Name="btnExportCsv" Content="📥  Export CSV" Width="130" Height="36"
                        Background="#0F172A" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="btnExportCsv_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
