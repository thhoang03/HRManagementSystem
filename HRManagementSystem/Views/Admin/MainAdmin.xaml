<Window x:Class="HRManagementSystem.Views.Admin.MainAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HRManagementSystem.Views.Admin"
        mc:Ignorable="d"
        Title="MainAdmin" Height="700" Width="1300" WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Loaded="MainAdmin_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <local:Sidebar/>
        </Grid>

        <Grid Grid.Column="1" Background="#F8FAFC">
            <Frame Grid.Row="1" x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>

    </Grid>
</Window>
