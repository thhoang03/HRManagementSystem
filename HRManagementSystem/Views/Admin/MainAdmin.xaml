<Window x:Class="HRManagementSystem.Views.Admin.MainAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HRManagementSystem.Views.Admin"
        mc:Ignorable="d"
        Title="MainAdmin" Height="700" Width="1300" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <local:Sidebar/>
        </Grid>

        <Grid Grid.Column="1" Background="#F8FAFC">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    BorderBrush="#E2E8F0" 
                    BorderThickness="0,0,0,1" 
                    Background="White">
                <DockPanel Margin="18,12">
                    <TextBlock x:Name="tblPageTitle"
                               VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="SemiBold" />
                </DockPanel>
            </Border>

            <Frame Grid.Row="1" x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>

    </Grid>
</Window>
