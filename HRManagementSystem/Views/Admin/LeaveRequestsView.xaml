<Page x:Name="frmLeaveRequests"
      x:Class="HRManagementSystem.Views.Admin.LeaveRequestsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Loaded="frmLeaveRequests_Loaded"
      Background="#F8FAFC">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Leave Requests Management"
                   Grid.Row="0"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="#0F172A"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,16" Orientation="Horizontal">

            <TextBox x:Name="txtSearch"
                     Width="220"
                     Height="36"
                     Padding="8"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     TextChanged="txtSearch_TextChanged"/>

            <Button Content="Search"
                    Width="90"
                    Height="36"
                    Background="#F9D678"
                    FontWeight="SemiBold"/>

        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="16">

            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.15"/>
            </Border.Effect>

            <DataGrid x:Name="dgLeaveRequests"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="34"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding LeaveId}"
                                        Width="1*"/>

                    <DataGridTextColumn Header="Employee"
                                        Binding="{Binding Employee.FullName}"
                                        Width="2*"/>

                    <DataGridTextColumn Header="Start Date"
                                        Binding="{Binding StartDate}"
                                        Width="1*"/>

                    <DataGridTextColumn Header="End Date"
                                        Binding="{Binding EndDate}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding LeaveType}"
                                        Width="1*"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Approved By"
                                        Binding="{Binding ApprovedByNavigation.FullName}"
                                        Width="2*"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</Page>
