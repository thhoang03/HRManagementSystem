<Window x:Class="HRManagementSystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HR Management System"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid>

        <Border Width="720"
                Height="400"
                Background="White"
                CornerRadius="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="25"
                                  ShadowDepth="4"
                                  Opacity="0.35"/>
            </Border.Effect>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL -->
                <Border Grid.Column="0"
                        Background="#0F172A"
                        CornerRadius="16,0,0,16">

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                        <Border Width="70"
                                Height="70"
                                Background="#F9D678"
                                CornerRadius="12"
                                Margin="0,0,0,20">

                            <TextBlock Text="HR"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Border>

                        <TextBlock Text="HR Management"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Human Resource System"
                                   FontSize="14"
                                   Foreground="#94A3B8"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Border>


                <!-- RIGHT PANEL -->
                <Grid Grid.Column="1"
                      Margin="50">

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="Login"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,30"/>


                        <!-- USERNAME -->
                        <TextBlock Text="Username"
                                   Foreground="#475569"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="txtUsername"
                                 Height="40"
                                 Padding="10"
                                 BorderThickness="1"
                                 BorderBrush="#CBD5E1"
                                 Margin="0,0,0,18"
                                 FontSize="14"/>


                        <!-- PASSWORD -->
                        <TextBlock Text="Password"
                                   Foreground="#475569"
                                   Margin="0,0,0,6"/>

                        <PasswordBox x:Name="txtPassword"
                                     Height="40"
                                     Padding="10"
                                     BorderThickness="1"
                                     BorderBrush="#CBD5E1"
                                     Margin="0,0,0,10"
                                     FontSize="14"/>


                        <CheckBox Content="Remember me"
                                  Foreground="#64748B"
                                  Margin="0,0,0,24"/>


                        <!-- LOGIN BUTTON -->
                        <Button Content="Login"
                                Height="44"
                                FontWeight="Bold"
                                Background="#F9D678"
                                Foreground="#0F172A"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="btnLogin_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8">

                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"
                                                    Value="#FACC15"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                    </StackPanel>

                </Grid>

            </Grid>

        </Border>

    </Grid>
</Window>